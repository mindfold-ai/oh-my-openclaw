{
	"id": "ohmyopenclaw-inbox-assistant",
	"name": "Oh My OpenClaw Inbox Assistant",
	"description": "Reads handbook inbox assignments and injects context into assigned agents.",
	"configSchema": {
		"type": "object",
		"additionalProperties": false,
		"properties": {
			"handbookDir": { "type": "string" },
			"assignmentsDir": { "type": "string" },
			"maxAssignments": { "type": "number", "minimum": 1, "maximum": 20 },
			"onlyAgents": {
				"type": "array",
				"items": { "type": "string" }
			},
			"feedbackDir": { "type": "string" },
			"maxContextMessages": { "type": "number", "minimum": 1, "maximum": 50 }
		}
	}
}
